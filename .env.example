# =====================================================================
# Shared config for BOTH agents.
#
# Variables are namespaced by agent: WEATHER_* and PACKING_*.
# An unprefixed variable applies to both unless an agent overrides it.
# Resolution order: <AGENT>_FOO  ->  FOO  ->  built-in default
# =====================================================================

# --- Shared -----------------------------------------------------------
# Applies to both agents unless overridden with a WEATHER_/PACKING_ prefix.
AUTH_MODE=apikey
LOG_FORMAT=dev
DEBUG_BODY=false
TASK_TTL_MS=900000

# --- Weather agent ----------------------------------------------------
WEATHER_PORT=3000
WEATHER_API_KEY=weather-dev-key-change-me
WEATHER_AGENT_NAME=US Weather Agent
WEATHER_AGENT_VERSION=1.0.0
WEATHER_AGENT_ORG=Example Org
WEATHER_AGENT_ORG_URL=https://example.com

# The National Weather Service API requires a descriptive User-Agent with
# contact information. Replace the email with your own.
WEATHER_NWS_USER_AGENT=a2a-weather-agent (you@example.com)
WEATHER_HTTP_TIMEOUT_MS=10000

# Optional: force the weather agent's card `url` to a fixed public base URL.
# WEATHER_PUBLIC_URL=https://my-weather-agent.example.com

# --- Packing agent ----------------------------------------------------
PACKING_PORT=3001
PACKING_API_KEY=packing-dev-key-change-me
PACKING_AGENT_NAME=Trip Packing Agent
PACKING_AGENT_VERSION=1.0.0
PACKING_AGENT_ORG=Example Org
PACKING_AGENT_ORG_URL=https://example.com
PACKING_DEFAULT_TRIP_DAYS=3

# Optional: force the packing agent's card `url` to a fixed public base URL.
# PACKING_PUBLIC_URL=https://my-packing-agent.example.com

# --- Packing -> Weather delegation -----------------------------------
# Both of these AUTO-RESOLVE when the agents run together in this repo:
#   URL defaults to http://localhost:${WEATHER_PORT}
#   API key defaults to WEATHER_API_KEY above
# Set them explicitly only to point at a weather agent running elsewhere.
# PACKING_WEATHER_AGENT_URL=https://some-other-codespace-3000.app.github.dev
# PACKING_WEATHER_AGENT_API_KEY=that-agents-key

# Set to `off` to run the packing agent fully standalone
PACKING_WEATHER_ENRICHMENT=on

# Resilience tuning for the downstream call
PACKING_WEATHER_TIMEOUT_MS=8000
PACKING_WEATHER_CACHE_TTL_MS=300000
PACKING_WEATHER_BREAKER_THRESHOLD=3
PACKING_WEATHER_BREAKER_COOLDOWN_MS=60000
