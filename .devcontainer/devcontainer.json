{
  "name": "A2A Agents (weather + packing)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "forwardPorts": [3000, 3001],
  "portsAttributes": {
    "3000": {
      "label": "US Weather Agent",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Trip Packing Agent",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "npm install && cp -n .env.example .env || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "humao.rest-client"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
